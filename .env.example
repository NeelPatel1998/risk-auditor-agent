# Backend (copy to backend/.env or repo root .env for docker-compose)
OPENROUTER_API_KEY=
LLM_MODEL=deepseek/deepseek-chat-v3-0324
# Lower if OpenRouter returns HTTP 402 (insufficient credits for requested completion budget)
# LLM_MAX_TOKENS=2048
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
CORS_ORIGIN=http://localhost:5173
# Optional comma-separated extra origins (e.g. another dev port)
# CORS_ORIGINS=http://192.168.1.5:5173
CHUNK_SIZE=1000
MAX_UPLOAD_MB=50
RETRIEVAL_MAX_DISTANCE=1.25
# Embedding: batch size for OpenRouter (raise if small PDFs work but large ones return 502)
# EMBED_BATCH_SIZE=32
# Set to true to wipe all vector chunks (and PDFs under data/uploads) before each upload — single-document workflows
# CLEAR_CHROMA_ON_UPLOAD=false

# Frontend — create frontend/.env.local
# VITE_API_URL=http://localhost:8000
